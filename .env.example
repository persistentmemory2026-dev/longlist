# Longlist — Environment Variables
# Copy to .env and fill in your keys.
# Optional: .env.local (gitignored) is loaded after .env and overrides keys for local-only secrets.

# Required
ANTHROPIC_API_KEY=
OPENREGISTER_API_KEY=

# Stripe (live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AgentMail
AGENTMAIL_API_KEY=
AGENTMAIL_WEBHOOK_SECRET=
AGENTMAIL_FROM=briefing@longlist.email

# Anymailfinder (PREMIUM email lookup)
ANYMAILFINDER_API_KEY=

# Telegram (QA notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App
APP_URL=http://localhost:8000
DATABASE_PATH=longlist.db
LONGLIST_ADMIN_TOKEN=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
